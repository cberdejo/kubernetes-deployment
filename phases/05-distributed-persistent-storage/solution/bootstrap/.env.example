# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# PostgreSQL credentials
POSTGRES_USER=admin
POSTGRES_PASSWORD=changeme
POSTGRES_DB=domain

# Docker Hub — used to push/pull app images
DOCKERHUB_USER=your-dockerhub-username
IMAGE_TAG=1.0.0

# Helm release name for todo-app (default: my-app).
# Change this only if you deploy with a different release name.
RELEASE_NAME=my-app
